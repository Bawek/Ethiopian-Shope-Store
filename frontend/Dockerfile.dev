# ============================================================================
# DEVELOPMENT DOCKERFILE FOR NEXT.JS
# Optimized for hot-reload
# ============================================================================

FROM node:20.11.0-alpine

WORKDIR /app

# Install development dependencies
RUN apk add --no-cache curl

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

# Expose port
EXPOSE 3000

# Start with next dev for hot-reload
CMD ["npm", "run", "dev"]
