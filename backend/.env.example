# ============================================================================
# BACKEND ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=production
PORT=8000
HOST=0.0.0.0

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string (Neon, AWS RDS, or local Postgres)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/ethiopian_shop?sslmode=disable
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_TIMEOUT=30000
DATABASE_IDLE_TIMEOUT=900000

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ============================================================================
# JWT & AUTHENTICATION
# ============================================================================
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-min-32-chars-long
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-min-32-chars-long
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ============================================================================
# PAYMENT GATEWAY (CHAPA)
# ============================================================================
CHAPA_SECRET_KEY=your-chapa-secret-key
CHAPA_PUBLIC_KEY=your-chapa-public-key
CHAPA_ENCRYPTION_KEY=your-chapa-encryption-key
CHAPA_API_URL=https://api.chapa.co/v1

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-email@gmail.com
EMAIL_SERVER_PASSWORD=your-app-password
EMAIL_SENDER_NAME=Ethiopian Shop Store
ADMIN_EMAIL=admin@ethiopianshop.com

# ============================================================================
# SECURITY
# ============================================================================
SIGNING_SECRET=your-webhook-signing-secret-min-32-chars-long
CORS_ORIGIN=http://localhost:3000,https://ethiopianshop.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# OPTIONAL: AI/ML SERVICES
# ============================================================================
GEMINI_API_KEY=your-gemini-api-key-optional

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# REDIS (Optional - for caching/sessions)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# STORAGE (Optional - for file uploads)
# ============================================================================
STORAGE_TYPE=local
STORAGE_PATH=./uploads
# OR for S3:
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket

# ============================================================================
# DEPLOYMENT ENVIRONMENT
# ============================================================================
DEPLOYMENT_ENV=production
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_VERSION=1.0.0
